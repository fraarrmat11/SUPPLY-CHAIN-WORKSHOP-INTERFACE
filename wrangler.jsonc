{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "supply-chain-workshop-interface",
  "compatibility_date": "2026-05-19",
  "main": "_worker.js",
  "assets": {
    "directory": "dist/MAP-INTERFACE/browser",
